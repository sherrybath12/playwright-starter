{
  "name": "playwright-starter",
  "version": "1.0.0",
  "scripts": {
    "test": "npx playwright test",
    "test:pytest": "python3 -m pytest -q",
    "test:ui": "npx playwright test --project=ui",
    "test:api": "npx playwright test --project=api",
    "report": "npx playwright show-report",
    "cucumber": "cucumber-js --require-module ts-node/register --require 'features/**/*.ts' features"
  },
  "description": "Playwright + TypeScript test framework",
  "devDependencies": {
    "@cucumber/cucumber": "^13.0.0",
    "@playwright/test": "^1.60.0",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^25.9.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1066.0",
    "mime-types": "^3.0.2"
  }
}
